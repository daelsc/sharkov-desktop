{"name":"sharkord-desktop","version":"0.1.42","description":"Electron desktop app for Sharkord — voice, video, and text chat","author":"Sharkord Desktop contributors","license":"MIT","private":true,"main":"dist/main.js","scripts":{"copy-worklet":"node scripts/copy-noise-worklet.js","build":"npm run copy-worklet && node scripts/generate-build-id.js && tsc && npm run minify","dev":"npm run build && electron .","start":"electron .","lint":"eslint src --ext ts","check-types":"tsc --noEmit","minify":"terser static/wrapper.js -c -m -o static/wrapper.min.js","minify:watch":"node scripts/watch-minify.js","pack":"npm run build && electron-builder && node scripts/rename-artifacts.js","pack:dir":"npm run build && electron-builder --dir","postinstall":"node scripts/install-custom-electron.js"},"dependencies":{"electron-store":"^10.0.0","electron-updater":"^6.8.3","koffi":"^2.9.0"},"devDependencies":{"@sapphi-red/web-noise-suppressor":"^0.3.5","@types/node":"^22.0.0","electron":"39.2.7","electron-builder":"^25.0.0","terser":"^5.36.0","typescript":"~5.8.3"},"build":{"appId":"com.sharkord.desktop","productName":"Sharkord","directories":{"output":"out"},"files":["dist/**","static/**","native/build/Release/*.node"],"win":{"target":["nsis","portable"],"icon":"static/icon.ico","publisherName":"Bugel"},"mac":{"target":["dmg"],"category":"public.app-category.social-networking"},"linux":{"target":["AppImage"]},"publish":[{"provider":"github","owner":"daelsc","repo":"sharkorddesktop"}]}}