{
  "name": "sharkov-desktop",
  "version": "0.1.54",
  "description": "Electron desktop app for Sharkov — voice, video, and text chat",
  "author": "Sharkov Desktop contributors",
  "license": "MIT",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "copy-worklet": "node scripts/copy-noise-worklet.js",
    "build": "npm run copy-worklet && tsc && npm run minify",
    "dev": "npm run build && electron .",
    "start": "electron .",
    "lint": "eslint src",
    "check-types": "tsc --noEmit",
    "minify": "terser static/wrapper.js -c -m -o static/wrapper.min.js",
    "minify:watch": "node scripts/watch-minify.js",
    "pack": "npm run build && electron-builder --dir",
    "pack:dir": "npm run build && electron-builder --dir",
    "postinstall": "node scripts/install-custom-electron.js"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "koffi": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@sapphi-red/web-noise-suppressor": "^0.3.5",
    "@types/node": "^22.0.0",
    "electron": "39.2.7",
    "electron-builder": "^25.0.0",
    "eslint": "^9.18.0",
    "terser": "^5.36.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.21.0"
  },
  "build": {
    "appId": "com.sharkov.desktop",
    "productName": "Sharkov",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**",
      "static/**",
      "native/build/Release/*.node"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "static/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.social-networking"
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "daelsc",
        "repo": "sharkov-desktop",
        "releaseType": "release"
      }
    ]
  }
}
